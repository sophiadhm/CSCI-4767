@EndUserText.label: 'Employee Query'
define view entity Z##_C_EmployeeQuery
  as select from Z##_R_Employee
{
  key EmployeeId,
      FirstName,
      LastName,
      DepartmentId,

      _Department.Description           as DepartmentDescription,
      _Department._Assistant.LastName   as AssistantName,

      /* Associations */
      _Department
}
